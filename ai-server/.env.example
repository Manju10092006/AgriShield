# ═══════════════════════════════════════════════════
# AgriShield AI — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys

# Gemini API Key (for advisory, vision, risk forecast)
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI API Key (for chatbot, optional)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenWeatherMap API Key (for weather data, optional)
# Get yours at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Server Port (default: 4000)
PORT=4000
